@using Orbyss.Blazor.JsonForms.Core

<CascadingValue Value="@componentFactory">
    <CascadingValue Value="@formContext">
        @if (navigationInstance is not null)
        {
            var pages = formContext.GetPages();
            @if (pages.Count() == 1)
            {
                <FormSinglePage OnSubmitClicked="@GetOnSubmitClickedEventCallback" Page="@(pages.First())" HideSubmitButton="@HideSubmitButton" />
            }
            else
            {
                <DynamicComponent Type="@navigationInstance.ComponentType" Parameters="navigationInstance.Parameters" />
            }
        }
    </CascadingValue>
</CascadingValue>

@code {
    [Parameter]
    public bool HideSubmitButton { get; set; }

    [Inject]
    IServiceProvider ServiceProvider { get; set; } = default!;

    [Parameter]
    public IFormComponentFactory? ComponentFactory { get; set; }   

    [Parameter, EditorRequired]
    public JsonFormOptions? Options { get; set; }

    [Parameter]
    public IJsonFormContext? FormContext { get; set; }

    [Parameter]
    public EventCallback<JToken> OnSubmit { get; set; }

    [CascadingParameter]
    public string? Language { get; set; }

    [CascadingParameter(Name = nameof(Disabled))]
    public bool? Disabled { get; set; }

    [CascadingParameter(Name = nameof(ReadOnly))]
    public bool? ReadOnly { get; set; }

    EventCallback? GetOnSubmitClickedEventCallback => OnSubmit.HasDelegate
       ? new EventCallback(this, Submit)
       : null;

    IComponentInstance navigationInstance = default!;
    IFormComponentFactory componentFactory = default!;
    IJsonFormContext formContext = default!;

    private Task Submit()
    {
        if (formContext!.Validate() && OnSubmit.HasDelegate)
            return OnSubmit.InvokeAsync(formContext.GetFormData());

        return Task.CompletedTask;
    }

    protected override void OnInitialized()
    {
        componentFactory = ResolveFactory();
        formContext = ResolveFormContext();

        navigationInstance = componentFactory.CreateNavigation(formContext);
        navigationInstance
            .SetParameter(FormComponentParameterKeys.OnSubmitClicked,  GetOnSubmitClickedEventCallback)
            .SetParameter(FormComponentParameterKeys.HideSubmitButton, HideSubmitButton);
    }

    protected override Task OnParametersSetAsync()
    {
        if (formContext is null)
            return Task.CompletedTask;

        if (!string.IsNullOrWhiteSpace(Language) && Language != formContext.ActiveLanguage)
            formContext.ChangeLanguage(Language!);

        if (Disabled.HasValue && Disabled != formContext.Disabled)
            formContext.ChangeDisabled(Disabled.Value);

        if (ReadOnly.HasValue && ReadOnly != formContext.ReadOnly)
            formContext.ChangeReadOnly(ReadOnly.Value);

        return Task.CompletedTask;
    }

    private IFormComponentFactory ResolveFactory()
    {
        // Full manual control: caller supplied a ready composite.
        if (ComponentFactory is not null)
            return ComponentFactory;

        // No per-form overrides: use the registered composite (lets a UI layer register a fully
        // custom IFormComponentFactory router). Falls back to building one from the sub-factories.
        if (Options?.ConfigureFactories is null)
            return ServiceProvider.GetService<IFormComponentFactory>() ?? BuildComposite(null);

        // Per-form overrides: build a composite from this form's own (transient) sub-factories and
        // apply the overrides on top of the application defaults.
        var options = new FormComponentFactoryOptions();
        Options.ConfigureFactories(options);
        return BuildComposite(options);
    }

    private IFormComponentFactory BuildComposite(FormComponentFactoryOptions? options)
    {
        var control      = Required<IControlComponentFactory>();
        var button       = Required<IButtonComponentFactory>();
        var navigation   = Required<INavigationComponentFactory>();
        var list         = Required<IListComponentFactory>();
        var actionButton = Required<IActionButtonComponentFactory>();
        var arrayLayout  = Required<IArrayLayoutComponentFactory>();

        options?.ApplyTo(control, button, navigation, list, actionButton, arrayLayout);

        return new FormComponentFactory(control, button, navigation, list, actionButton, arrayLayout);
    }

    private T Required<T>() where T : class
        => ServiceProvider.GetService<T>()
            ?? throw new InvalidOperationException(
                $"No '{typeof(T).Name}' is registered. Register a UI layer (e.g. AddSyncfusionJsonForms / " +
                $"AddJsonForms with configured factories) or pass a ComponentFactory to <JsonForm>.");

    private IJsonFormContext ResolveFormContext()
    {
        if (Options is null)
            throw new ArgumentException("Options must be specified.");

        if (FormContext is not null)
        {
            if (FormContext.PageCount == 0)
                FormContext.Instantiate(Options);
            return FormContext;
        }

        var service = ServiceProvider.GetService<IJsonFormContext>();
        if (service is not null)
        {
            service.Instantiate(Options);
            return service;
        }

        return JsonFormContextBuilder.BuildAndInstantiate(Options);
    }
}
